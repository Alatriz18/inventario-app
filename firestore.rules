rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuth() && getUser().rol == role && getUser().activo == true;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isStaff() {
      return isAuth() && getUser().activo == true &&
        getUser().rol in ['admin', 'vendedor', 'bodeguero', 'contador', 'finanzas'];
    }

    function isFinanzas() {
      return isAdmin() || hasRole('finanzas');
    }

    function isContador() {
      return isAdmin() || hasRole('contador');
    }

    // Users: solo admin puede gestionar
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // ── Configuración del sistema ─────────────────────────────────────────

    // config_sri contiene el certificado .p12 — lectura staff (para emitir).
    // Escritura completa solo admin; el staff solo puede incrementar los
    // secuenciales al emitir comprobantes (no puede tocar certificado/clave).
    match /config_sri/{id} {
      allow read: if isStaff();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (isStaff() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'secuencialFactura', 'secuencialNotaVenta', 'secuencialRetencion',
            'secuencialNotaCredito', 'secuencialNotaDebito',
            'secuencialLiquidacion', 'secuencialGuia'
          ]));
    }

    match /config_empresa/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /config_contable/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    // config_email contiene credenciales SMTP — lectura staff (para enviar), escritura admin
    match /config_email/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Inventario ────────────────────────────────────────────────────────

    match /productos/{id} {
      allow read:   if isStaff();
      allow create: if isAdmin() || hasRole('bodeguero') || hasRole('finanzas');
      allow update: if isAdmin() || hasRole('bodeguero') || hasRole('finanzas') || hasRole('vendedor');
      allow delete: if isAdmin();
    }

    match /categorias/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /proveedores/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('bodeguero');
    }

    match /clientes/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /bodegas/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /entradas/{id} {
      allow read: if isStaff();
      allow create: if isAdmin() || hasRole('bodeguero') || hasRole('finanzas');
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /despachos/{id} {
      allow read: if isStaff();
      allow create: if isAdmin() || hasRole('bodeguero') || hasRole('finanzas');
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /movimientos/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // ── Ventas ────────────────────────────────────────────────────────────

    match /ventas/{id} {
      allow read:   if isStaff();
      allow create: if isAdmin() || hasRole('vendedor');
      allow update: if isAdmin() || hasRole('vendedor');
      allow delete: if false;
    }

    // ── Facturación SRI ───────────────────────────────────────────────────

    match /comprobantes/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('vendedor');
    }

    match /notas_credito/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('vendedor') || hasRole('contador');
    }

    match /notas_debito/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('vendedor') || hasRole('contador');
    }

    // ── Cuentas por Cobrar ────────────────────────────────────────────────

    match /cuentas_cobrar/{id} {
      allow read: if isStaff();
      allow create: if isAdmin() || hasRole('vendedor') || hasRole('contador') || hasRole('finanzas');
      allow update: if isAdmin() || hasRole('vendedor') || hasRole('contador') || hasRole('finanzas');
      allow delete: if isAdmin();
    }

    // ── Cuentas por Pagar ─────────────────────────────────────────────────

    match /facturas_proveedor/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('contador') || hasRole('bodeguero') || hasRole('finanzas');
    }

    // Notas de crédito / débito recibidas de proveedores (importadas por XML)
    match /documentos_recibidos/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('contador') || hasRole('bodeguero') || hasRole('finanzas');
    }

    match /pagos_proveedor/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('contador') || hasRole('finanzas');
    }

    // ── Contabilidad ──────────────────────────────────────────────────────

    match /cuentas_contables/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    match /asientos/{id} {
      allow read:   if isStaff();
      allow create: if isContador() || hasRole('finanzas') || hasRole('vendedor');
      allow update: if isContador() || hasRole('finanzas');
      allow delete: if isAdmin() || hasRole('vendedor');
    }

    match /periodos_contables/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    match /centros_costo/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    // ── Tributario ────────────────────────────────────────────────────────

    match /retenciones_config/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    match /ice_config/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    match /retenciones_emitidas/{id} {
      allow read: if isStaff();
      allow create: if isAdmin() || hasRole('contador') || hasRole('vendedor');
      allow update: if isAdmin() || hasRole('contador');
      allow delete: if isAdmin();
    }

    match /retenciones_recibidas/{id} {
      allow read: if isStaff();
      allow create: if isAdmin() || hasRole('contador') || hasRole('vendedor');
      allow update: if isAdmin() || hasRole('contador');
      allow delete: if isAdmin();
    }

    // ── Activos Fijos ─────────────────────────────────────────────────────

    match /activos_fijos/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('contador');
    }

    // ── Conciliación Bancaria ─────────────────────────────────────────────

    match /cuentas_bancarias/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('contador');
    }

    match /movimientos_bancarios/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('contador');
    }
  }
}



