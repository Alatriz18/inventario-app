rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuth() && getUser().rol == role && getUser().activo == true;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isStaff() {
      return isAuth() && getUser().activo == true &&
        getUser().rol in ['admin', 'vendedor', 'bodeguero', 'contador'];
    }

    function isContador() {
      return isAdmin() || hasRole('contador');
    }

    // Users: solo admin puede gestionar
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Inventario
    match /productos/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('bodeguero');
    }

    match /categorias/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /proveedores/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('bodeguero');
    }

    match /clientes/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    match /bodegas/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /entradas/{id} {
      allow read: if isStaff();
      allow create: if isAdmin() || hasRole('bodeguero');
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /despachos/{id} {
      allow read: if isStaff();
      allow create: if isAdmin() || hasRole('bodeguero');
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /movimientos/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // Ventas
    match /ventas/{id} {
      allow read: if isStaff();
      allow create: if isAdmin() || hasRole('vendedor');
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Facturación
    match /comprobantes/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('vendedor');
    }

    // Cuentas por pagar
    match /facturas_proveedor/{id} {
      allow read: if isStaff();
      allow write: if isAdmin() || hasRole('contador') || hasRole('bodeguero');
    }

    // Contabilidad
    match /cuentas_contables/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    match /asientos/{id} {
      allow read: if isStaff();
      allow create: if isContador();
      allow update: if isContador();
      allow delete: if isAdmin();
    }

    match /periodos_contables/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    match /centros_costo/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    match /config_contable/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    // Tributario
    match /retenciones_config/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }

    match /ice_config/{id} {
      allow read: if isStaff();
      allow write: if isContador();
    }
  }
}
